rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /user_uploads/{userId}/avatars/{fileName} {
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
      allow get: if true;
      allow list: if false;
    }

    match /user_uploads/{userId}/posters/{fileName} {
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
      allow get: if true;
      allow list: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
